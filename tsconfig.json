{
	"compilerOptions": {
		"target": "ESNext",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"strict": true,
		"esModuleInterop": true,
		"declaration": true,
		"composite": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"rewriteRelativeImportExtensions": true,
		"noUncheckedIndexedAccess": true,
		"verbatimModuleSyntax": true,
		"incremental": true,
		"outDir": "dist",
		"rootDir": "src"
	},
	"include": ["src/**/*"],
	"exclude": ["dist/**/*"]
}
